#!/bin/sh

set -o errexit
set -o nounset

show_help() {
  cat >&2 <<EOF
usage: dca code <directory>

Open a directory in VS Code with devcontainer support.

Examples:
  dca code .
  dca code ~/experiments/myrepo-feature
EOF
}

if [ $# -eq 0 ]; then
  show_help
  exit 1
fi

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
  show_help
  exit 0
fi

if [ $# -ne 1 ]; then
  echo "Error: code requires exactly 1 argument" >&2
  show_help
  exit 1
fi

dir=$(cd "$1" && pwd)

if [ ! -d "$dir" ]; then
  echo "Error: '$1' is not a directory" >&2
  exit 1
fi

hex=$(printf '%s' "$dir" | xxd -p -c 256)

if ! config=$(devcontainer read-configuration --workspace-folder "$dir" 2>/dev/null); then
  echo "Error: no devcontainer configuration found in '$dir'" >&2
  exit 1
fi
workspace_folder=$(printf '%s' "$config" | jq -r '.workspace.workspaceFolder')

# VS Code Dev Containers resolves Docker via DOCKER_HOST, not the Docker CLI context.
# If the active context uses a non-default socket (e.g. Rancher Desktop, Docker Desktop),
# export DOCKER_HOST so VS Code inherits the correct endpoint.
if [ -z "${DOCKER_HOST:-}" ]; then
  docker_host=$(docker context inspect --format '{{.Endpoints.docker.Host}}' 2>/dev/null || true)
  if [ -n "$docker_host" ] && [ "$docker_host" != "unix:///var/run/docker.sock" ]; then
    export DOCKER_HOST="$docker_host"
  fi
fi

set -o xtrace
code --folder-uri "vscode-remote://dev-container+${hex}${workspace_folder}"
