#!/bin/sh

set -o errexit
set -o nounset

show_help() {
    cat >&2 <<EOF
usage: dca devcontainer <directory> [<devcontainer-args>...]

Start a devcontainer for the given directory, automatically injecting any
features stored via 'dca config' via --additional-features.

Examples:
  dca devcontainer .
  dca devcontainer ~/experiments/myrepo-feature
  dca devcontainer . --remove-existing-container
EOF
}

if [ $# -eq 0 ]; then
    show_help
    exit 1
fi

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    show_help
    exit 0
fi

# Validate required dependencies
if ! command -v jq >/dev/null 2>&1; then
    echo "Error: jq is required but not found on PATH" >&2
    exit 1
fi

if ! command -v devcontainer >/dev/null 2>&1; then
    echo "Error: devcontainer CLI is required but not found on PATH" >&2
    echo "       Install it with: npm install -g @devcontainers/cli" >&2
    exit 1
fi

dir=$(cd "$1" && pwd)
shift

if [ ! -d "$dir" ]; then
    echo "Error: '$dir' is not a directory" >&2
    exit 1
fi

# Read stored default features from dca config
DCA_CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/dca/config.json"

additional_features=""
if [ -f "$DCA_CONFIG_FILE" ]; then
    additional_features="$(jq -c '. // empty' "$DCA_CONFIG_FILE")"
fi

if [ -n "$additional_features" ]; then
    set -o xtrace
    exec devcontainer up --workspace-folder "$dir" --additional-features "$additional_features" "$@"
fi

set -o xtrace
exec devcontainer up --workspace-folder "$dir" "$@"
