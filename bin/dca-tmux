#!/bin/sh

set -o errexit
set -o nounset

show_help() {
    cat >&2 <<EOF
usage: dca tmux <directory> [<devcontainer-args>...]

Ensure a devcontainer is running for the given directory, then attach to a
persistent tmux session inside it. Tmux is automatically injected as a feature
if the container needs to be (re)built. Stored features from 'dca config' are
also injected.

Examples:
  dca tmux .
  dca tmux ~/experiments/myrepo-feature
  dca tmux . --remove-existing-container
EOF
}

if [ $# -eq 0 ]; then
    show_help
    exit 1
fi

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    show_help
    exit 0
fi

if ! command -v jq >/dev/null 2>&1; then
    echo "Error: jq is required but not found on PATH" >&2
    exit 1
fi

if ! command -v devcontainer >/dev/null 2>&1; then
    echo "Error: devcontainer CLI is required but not found on PATH" >&2
    echo "       Install it with: npm install -g @devcontainers/cli" >&2
    exit 1
fi

dir=$(cd "$1" && pwd)
shift

if [ ! -d "$dir" ]; then
    echo "Error: '$dir' is not a directory" >&2
    exit 1
fi

# shellcheck source=dca-lib
. "$(dirname "$0")/dca-lib"

dca_up_with_tmux "$dir" "$@"
dca_require_tmux "$dir" "dca tmux $(printf '%s' "$dir") --remove-existing-container"

set -o xtrace
exec devcontainer exec --workspace-folder "$dir" tmux new-session -A -s main
